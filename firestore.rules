rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions for validation
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUserUpdate() {
      // Prevent modification of protected fields
      let incomingData = request.resource.data;
      let existingData = resource.data;

      // UID cannot be changed
      return incomingData.keys().hasOnly([
          'uid',
          'displayName',
          'accountSelection',
          'emailAddress',
          'timezone',
          'categories',
          'categoriesSkipped',
          'eras',
          'notificationEnabled',
          'notificationTime',
          'pushPermission',
          'heroPreviewSeen',
          'themePreference',
          'additionalNotes',
          'onboardingCompleted',
          'savedEventIds',
          'likedEventIds',
          'reactions',
          'createdAt',
          'updatedAt'
        ])
        && (!('accountSelection' in incomingData)
          || incomingData.accountSelection == null
          || incomingData.accountSelection in ['anonymous', 'google', 'apple', 'email'])
        && (!('pushPermission' in incomingData)
          || incomingData.pushPermission in ['enabled', 'declined', 'unknown'])
        && (!('themePreference' in incomingData)
          || incomingData.themePreference in ['light', 'dark', 'system'])
        && (!('uid' in incomingData) || incomingData.uid == request.auth.uid)
        // createdAt cannot be changed once set
        && (!('createdAt' in existingData) || !('createdAt' in incomingData) || incomingData.createdAt == existingData.createdAt)
        // Validate data types
        && (!('displayName' in incomingData) || incomingData.displayName is string)
        && (!('emailAddress' in incomingData) || incomingData.emailAddress is string)
        && (!('timezone' in incomingData) || incomingData.timezone is string)
        && (!('notificationTime' in incomingData) || incomingData.notificationTime is string)
        && (!('additionalNotes' in incomingData) || incomingData.additionalNotes is string)
        && (!('savedEventIds' in incomingData) || incomingData.savedEventIds is list)
        && (!('likedEventIds' in incomingData) || incomingData.likedEventIds is list)
        && (!('reactions' in incomingData) || incomingData.reactions is map)
        && (!('categories' in incomingData) || incomingData.categories is list)
        && (!('eras' in incomingData) || incomingData.eras is list)
        && (!('onboardingCompleted' in incomingData) || incomingData.onboardingCompleted is bool)
        && (!('categoriesSkipped' in incomingData) || incomingData.categoriesSkipped is bool)
        && (!('notificationEnabled' in incomingData) || incomingData.notificationEnabled is bool);
    }

    function isValidSavedEventWrite(eventId) {
      return request.resource.data.keys().hasOnly(['eventId', 'savedAt', 'updatedAt'])
        && request.resource.data.eventId == eventId
        && (!('savedAt' in request.resource.data) || request.resource.data.savedAt is timestamp)
        && (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp);
    }

    // Users collection - users can only read and write their own document with validation
    match /Users/{userId} {
      // Allow read only for own document
      allow read: if isOwner(userId);

      // Allow create only for own document with valid initial data
      allow create: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'uid',
          'displayName',
          'accountSelection',
          'emailAddress',
          'timezone',
          'categories',
          'categoriesSkipped',
          'eras',
          'notificationEnabled',
          'notificationTime',
          'pushPermission',
          'heroPreviewSeen',
          'themePreference',
          'additionalNotes',
          'onboardingCompleted',
          'savedEventIds',
          'likedEventIds',
          'reactions',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.keys().hasAll(['uid', 'onboardingCompleted']);

      // Allow update only for own document with validation
      allow update: if isOwner(userId) && isValidUserUpdate();

      // Prevent deletion of user documents
      allow delete: if false;

      match /savedEvents/{eventId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidSavedEventWrite(eventId);
        allow delete: if isOwner(userId);
      }
    }

    // Content events - readable by all authenticated users (including anonymous)
    match /contentEvents/{eventId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only server-side ingestion can write
    }

    // Daily digests - readable by all authenticated users
    match /dailyDigests/{digestId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only server-side ingestion can write
    }

    // Story of the day - readable by all authenticated users
    match /storyOfTheDay/{sotdId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only server-side processes can write
    }
  }
}
